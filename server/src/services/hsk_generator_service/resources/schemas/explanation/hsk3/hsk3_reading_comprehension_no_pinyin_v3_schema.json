            "vietnamese_translation": { "type": "string" }
          },
          "required": ["chinese_text", "vietnamese_translation"]
        },
        "options": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "letter": { "type": "string" },
              "chinese_text": { "type": "string" },
              "vietnamese_translation": { "type": "string" }
