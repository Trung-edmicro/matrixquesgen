{
  "type": "object",
  "description": "Cấu trúc lời giải cho câu hỏi đọc hiểu không pinyin V3 của HSK3.",
  "properties": {
    "analysis_paragraph": {
      "type": "string",
      "description": "Lời giải thích thật ngắn gọn bằng tiếng Việt, trích dẫn thông tin quan trọng từ đoạn văn để giải thích tại sao đáp án là đúng."
    },
    "translation_block": {
      "type": "object",
      "description": "Khối 'Tạm dịch' chứa kịch bản gốc và bản dịch tiếng Việt tương ứng.",
