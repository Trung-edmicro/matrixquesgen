{
  "type": "object",
  "properties": {
    "topik_listening_vocab": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "question_id": { "type": "integer" },
          "target_korean": { 
            "type": "string", 
            "description": "Từ vựng dùng làm file nghe. Ví dụ: '수요일'" 
          },
          "options": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "vietnamese": { "type": "string", "description": "Nghĩa tiếng Việt (Hiển thị cột G). VD: 'Thứ tư'" },
                "korean_equiv": { "type": "string", "description": "Từ tiếng Hàn tương ứng (Hiển thị cột I). VD: '수요일'" },
                "note": { "type": "string", "description": "Phiên âm hoặc ghi chú nếu có. VD: '/이월/' hoặc để trống." },
                "is_correct": { "type": "boolean" }
